package() {
    install -d \
        ${pkgdir}/usr/share/icons/hicolor/scalable/apps \
        ${pkgdir}/usr/share/icons/hicolor/16x16/apps \
        ${pkgdir}/usr/share/icons/hicolor/24x24/apps \
